# Environment Variables for CommunityHub
# Copy this file to .env and fill in your actual values

# Backblaze B2 Configuration
B2_APPLICATION_KEY_ID=YOUR_B2_KEY_ID
B2_APPLICATION_KEY=YOUR_B2_APP_KEY
B2_BUCKET_NAME=YOUR_B2_BUCKET_NAME
B2_DOWNLOAD_URL=https://fXXX.backblazeb2.com

# MongoDB Configuration
MONGO_URL=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/DATABASE?retryWrites=true&w=majority

# Email Configuration
MAIL_URL=smtp://SMTP_USER:SMTP_PASSWORD@smtp-relay.brevo.com:587
SMTP_USER=SMTP_USER
SMTP_PASSWORD=SMTP_PASSWORD
EMAIL_FROM=your@email.com

# Super Admin Configuration
SUPERADMIN_EMAIL=admin@yourdomain.com
SUPERADMIN_PASSWORD=YourSecurePasswordHere!

# Security Settings
BCRYPT_ROUNDS=12
SESSION_TIMEOUT=604800000
